{
  "name": "soulrust-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript Connect-Web frontend for soulrust's soulrust.api.v1 Connect API.",
  "scripts": {
    "generate": "buf generate ../proto --template buf.gen.yaml",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.47.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
